# Model name for sentence transformer
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Choose your LLM provider: "openai", "anthropic", "gemini", or "ollama"
LLM_PROVIDER=ollama

# OpenAI (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Anthropic (only needed if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google Gemini (only needed if LLM_PROVIDER=gemini)
GEMINI_API_KEY=your-key-here
GEMINI_MODEL=gemini-2.0-flash

# Ollama (only needed if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
